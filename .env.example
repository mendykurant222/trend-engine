# Copy to .env and fill in. NEVER commit .env.

# Supabase Postgres — Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Reddit "script" app — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Google Trends via SerpApi — https://serpapi.com
SERPAPI_KEY=

# Amazon via Keepa — https://keepa.com/#!api
KEEPA_KEY=

# TikTok Creative Center via Apify — https://apify.com
APIFY_TOKEN=

# Claude (Phase 3)
ANTHROPIC_API_KEY=

# Daily summary email — https://resend.com
RESEND_API_KEY=
REPORT_FROM="Trend Engine <onboarding@resend.dev>"

# Telegram bot (create via @BotFather; chat id via @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
